############################
# EUREKA SERVICE DISCOVERY #
############################
EUREKA_CLIENT_SERVICEURL_DEFAULTZONE=http://service-discovery:8761/eureka/
EUREKA_CLIENT_REGISTER_WITH_EUREKA=false
EUREKA_CLIENT_FETCH_REGISTRY=false
EUREKA_INSTANCE_HOSTNAME=service-discovery
EUREKA_INSTANCE_PORT=8761

#####################
# API GATEWAY CONFIG #
#####################
API_GATEWAY_INSTANCE_HOSTNAME=gateway
API_GATEWAY_INSTANCE_PORT=8080

###########################
# AUTH-SERVICE CONFIG     #
###########################
AUTH_SERVICE_INSTANCE_HOSTNAME=auth-service
AUTH_SERVICE_INSTANCE_PORT=8081
AUTH_MONGODB_HOST=mongo-auth
AUTH_MONGODB_PORT=27017
AUTH_MONGODB_DATABASE=authservicedb
AUTH_MONGODB_URI=mongodb://mongo-auth:27017/authservicedb

#############################
# PROMETHEUS CONFIGURATION  #
#############################
PROMETHEUS_INSTANCE_HOSTNAME=prometheus
PROMETHEUS_INSTANCE_PORT=9090

#############################
# GRAFANA CONFIGURATION     #
#############################
GRAFANA_INSTANCE_HOSTNAME=grafana
GRAFANA_INSTANCE_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

#############################
# GLOBAL MONGODB DEFAULTS   #
#############################
MONGODB_DEFAULT_PORT=27017
MONGODB_VOLUME_PATH=/data/db

#############################
# NETWORK CONFIGURATION     #
#############################
SMARTGYM_NETWORK=smartgym-net